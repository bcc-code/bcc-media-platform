{
    "name": "web",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:prod": "vite --mode prod",
        "dev:sta": "vite --mode sta",
        "dev:dev": "vite --mode dev",
        "build": "vue-tsc --noEmit && vite build",
        "build:prod": "vue-tsc --noEmit && vite build --mode prod",
        "build:sta": "vue-tsc --noEmit && vite build --mode sta",
        "build:dev": "vue-tsc --noEmit && vite build --mode dev",
        "revision": "echo $GITHUB_SHA > ./public/revision",
        "preview": "vite preview",
        "prettier": "prettier --write .",
        "generate": "graphql-codegen --config codegen.yml",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@auth0/auth0-vue": "^2.7.0",
        "@bcc-code/bmm-sdk-fetch": "8.8.8",
        "@headlessui/vue": "^1.7.23",
        "@heroicons/vue": "^2.2.0",
        "@sentry/browser": "^10.58.0",
        "@sentry/vue": "^10.58.0",
        "@takuma-ru/vue-swipe-modal": "^5.0.5",
        "@types/showdown": "^2.0.6",
        "@unleash/proxy-client-vue": "^0.1.6",
        "@urql/exchange-auth": "2.2.1",
        "@urql/vue": "1.4.3",
        "@vueuse/core": "^14.3.0",
        "@vueuse/motion": "^3.0.3",
        "bccm-video-player": "^3.3.4",
        "graphql": "^16.14.2",
        "graphql-tag": "^2.12.7",
        "hls.js": "^1.6.16",
        "rudder-sdk-js": "^2.52.14",
        "showdown": "^2.1.0",
        "swiper": "^12.2.0",
        "vue": "^3.5.38",
        "vue-i18n": "^11.4.6",
        "vue-router": "^5.1.0",
        "vue3-lottie": "^3.3.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@graphql-codegen/cli": "5.0.7",
        "@graphql-codegen/typescript": "4.1.6",
        "@graphql-codegen/typescript-operations": "4.6.1",
        "@graphql-codegen/typescript-vue-urql": "3.2.1",
        "@intlify/unplugin-vue-i18n": "^11.2.4",
        "@tailwindcss/postcss": "4.3.1",
        "@tailwindcss/typography": "^0.5.20",
        "@types/node": "^25.9.3",
        "@typescript-eslint/parser": "^8.61.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.6.0",
        "postcss": "^8.5.15",
        "prettier": "^3.8.4",
        "tailwindcss": "^4.3.1",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.16",
        "vue-eslint-parser": "^10.3.0",
        "vue-tsc": "^3.3.5"
    },
    "packageManager": "pnpm@9.7.1"
}
