{
    "name": "bccm-video-player-v10",
    "version": "0.0.0-dev",
    "type": "commonjs",
    "types": "build/types/index.d.ts",
    "files": [
        "build"
    ],
    "exports": {
        ".": {
            "types": "./build/types/index.d.ts",
            "import": "./build/bccm-video-player.mjs",
            "require": "./build/bccm-video-player.umd.js"
        },
        "./css": "./build/bccm-video-player.css"
    },
    "scripts": {
        "dev": "vite",
        "types": "tsc --emitDeclarationOnly && mv build/src build/types && rm -r build/external-projects",
        "build": "tsc --noEmit && vite build && pnpm types",
        "preview": "vite preview",
        "prettier": "prettier --write ."
    },
    "dependencies": {
        "@silvermine/videojs-chromecast": "^1.5.0",
        "graphql": "^16.13.2",
        "graphql-request": "^7.4.0",
        "npaw-plugin-adapters": "^7.3.29",
        "npaw-plugin-nwf": "^7.3.29",
        "ua-parser-js": "^2.0.9",
        "video.js": "^8.23.7",
        "videojs-contrib-quality-levels": "^4.1.0",
        "videojs-event-tracking": "^1.0.3",
        "videojs-mux": "^4.21.28"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/ua-parser-js": "^0.7.39",
        "@vitejs/plugin-vue": "^6.0.6",
        "postcss": "^8.5.14",
        "prettier": "^3.8.3",
        "sass": "^1.99.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vue": "^3.5.33"
    },
    "packageManager": "pnpm@9.14.4"
}
