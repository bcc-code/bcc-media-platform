{
    "name": "bccm-video-player",
    "version": "3.1.0",
    "type": "commonjs",
    "types": "build/types/index.d.ts",
    "files": [
        "build"
    ],
    "exports": {
        ".": {
            "types": "./build/types/index.d.ts",
            "import": "./build/bccm-video-player.mjs",
            "require": "./build/bccm-video-player.umd.js"
        },
        "./css": "./build/bccm-video-player.css"
    },
    "scripts": {
        "dev": "vite",
        "types": "tsc --emitDeclarationOnly",
        "build": "tsc --noEmit && vite build && pnpm types",
        "preview": "vite preview",
        "prettier": "prettier --write .",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@videojs/core": "10.0.0-beta.24",
        "@videojs/element": "10.0.0-beta.24",
        "@videojs/html": "10.0.0-beta.24",
        "graphql": "^16.14.0",
        "graphql-request": "^7.4.0",
        "hls.js": "^1.6.16",
        "npaw-plugin-adapters": "^7.3.30",
        "npaw-plugin-nwf": "^7.3.30"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/tsconfig": "^0.9.1",
        "postcss": "^8.5.15",
        "prettier": "^3.8.3",
        "sass": "^1.100.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7",
        "vue": "^3.5.34",
        "vue-tsc": "^3.3.1"
    },
    "packageManager": "pnpm@9.14.4"
}
