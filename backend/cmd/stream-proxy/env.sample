# General
PORT=8081
ENVIRONMENT=development

# Stream proxy
# Two upstream CDN hosts: one for direct CloudFront, one for ioriver.
# Per-request selection is driven by the JWT `provider` claim minted by
# backend/streamtoken; this default is used when the claim is absent.
STREAM_PROXY_CDN_DOMAIN_CLOUDFRONT=vod2-cf.brunstad.tv
STREAM_PROXY_CDN_DOMAIN_IORIVER=vod2.brunstad.tv
# Allowed values: "cloudfront", "ioriver".
STREAM_PROXY_DEFAULT_PROVIDER=ioriver
STREAM_PROXY_CACHE_TTL=10m
STREAM_PROXY_SIGN_TTL=6h

# JWT verification (HS256 with a shared secret).
# These MUST match the values configured in cmd/api and cmd/jobs.
STREAM_JWT_SECRET=<long random shared secret>
STREAM_JWT_ISSUER=https://api.brunstad.tv/

# Direct-CloudFront signing (used when the JWT provider claim is
# `cloudfront`). Single CDN, single key pair.
CF_SIGNING_KEY_PATH=./cloudfront-direct.rsa
CLOUDFRONT_DIRECT_SIGNING_KEY_ID=<CF_KEY_PAIR_ID>

# ioriver signing (used when the JWT provider claim is `ioriver` or absent
# with the default above). One ioriver-issued RSA key pair fans out into the
# per-sub-provider signature formats so any sub-provider ioriver routes to
# can validate.
IORIVER_SIGNING_KEY_PATH=./ioriver.rsa
IORIVER_CLOUDFRONT_KEY_ID=<IORIVER_CF_KEY_ID>
IORIVER_FASTLY_KEY_ID=<IORIVER_FASTLY_KEY_ID>
IORIVER_AKAMAI_KEY_ID=
IORIVER_AKAMAI_ENCRYPTION_KEY=

# Tracing
UPTRACE_DSN=
TRACE_SAMPLING_FREQUENCY=0
TRACE_PRETTY=true
