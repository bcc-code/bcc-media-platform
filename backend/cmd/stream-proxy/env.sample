# General
PORT=8081
ENVIRONMENT=development

# Stream proxy
STREAM_PROXY_CDN_DOMAIN=vod2.brunstad.tv
STREAM_PROXY_CACHE_TTL=10m
STREAM_PROXY_SIGN_TTL=6h

# JWT verification (HS256 with a shared secret).
# These MUST match the values configured in cmd/api and cmd/jobs.
STREAM_JWT_SECRET=<long random shared secret>
STREAM_JWT_ISSUER=https://api.brunstad.tv/

# CDN signing (used when serving variant playlists / non-index.m3u8 files;
# the same key material as cmd/api and cmd/sign-url)
CF_SIGNING_KEY_PATH=./key.rsa
CF_SIGNING_KEY_ID=<SIGNING_KEY_ID>
FASTLY_SIGNING_KEY_ID=
AKAMAI_SIGNING_KEY_ID=
AKAMAI_ENCRYPTION_KEY=

# Tracing
UPTRACE_DSN=
TRACE_SAMPLING_FREQUENCY=0
TRACE_PRETTY=true
